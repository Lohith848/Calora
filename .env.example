# ─── Required: Supabase ──────────────────────────────────────────────────────
# Create a project at https://supabase.com
# Go to Project Settings → API → Project URL & anon/public key
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
# Legacy fallback:
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Required: Gemini AI for food image analysis ─────────────────────────────
# Get a free API key at https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# ─── Required: RevenueCat for subscriptions ─────────────────────────────────
# From https://app.revenuecat.com → Project → API Keys
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=your-rc-android-key
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your-rc-ios-key

# ─── Optional: Sentry for crash reporting ───────────────────────────────────
# From https://sentry.io → Project → Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ─── Optional: PostHog for product analytics ────────────────────────────────
# From https://posthog.com → Project → Settings → Project API Key
EXPO_PUBLIC_POSTHOG_KEY=your-posthog-key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Supabase Social Login Configuration (for Google/Apple OAuth) ────────────
# Enable these providers in Supabase Dashboard → Auth → Providers
# Google: Set up OAuth consent screen in Google Cloud Console
# Apple: Configure Service ID in Apple Developer Portal
# Then set redirect URLs in each provider to:
#   {SUPABASE_URL}/auth/v1/callback

# ─── Supabase Edge Function Secrets ─────────────────────────────────────────
# REVENUECAT_WEBHOOK_SECRET=<set-via-supabase-secrets-set>
